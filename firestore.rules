rules_version = '2';

// Darak 앱 Firestore 보안 규칙
// 마지막 업데이트: 2026-01-28
//
// 보안 원칙:
// 1. 인증된 사용자만 데이터 접근 가능
// 2. 사용자는 자신의 데이터만 수정 가능
// 3. 관리자(admin, pastor)는 모든 데이터 접근 가능
// 4. 리더는 자신의 그룹/마을 데이터 접근 가능

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // 헬퍼 함수들
    // ============================================
    
    // 로그인 여부 확인
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // 본인 확인
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // 사용자 역할 가져오기
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    // 관리자 확인 (admin, pastor)
    function isAdmin() {
      let role = getUserRole();
      return role == 'admin' || role == 'pastor';
    }
    
    // 리더 확인 (darakLeader, villageLeader, evangelist, preacher, pastor, admin 포함)
    function isLeader() {
      let role = getUserRole();
      return role == 'darakLeader' || role == 'villageLeader' || 
             role == 'evangelist' || role == 'preacher' || 
             role == 'pastor' || role == 'admin';
    }
    
    // 유효한 타임스탬프 확인
    function hasValidTimestamps() {
      return request.resource.data.keys().hasAll(['createdAt', 'updatedAt']);
    }
    
    // ============================================
    // Users 컬렉션
    // ============================================
    match /users/{userId} {
      // 읽기: 본인 또는 리더는 모든 사용자 정보 조회 가능
      allow read: if isAuthenticated() && (isOwner(userId) || isLeader());
      
      // 생성: 본인 계정만 생성 가능 (회원가입 시)
      allow create: if isAuthenticated() && isOwner(userId);
      
      // 수정: 본인은 자신의 정보 수정 가능, 관리자는 모든 정보 수정 가능
      // 단, role 필드는 관리자만 변경 가능
      allow update: if isAuthenticated() && (
        (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) ||
        isAdmin()
      );
      
      // 삭제: 관리자만 가능
      allow delete: if isAuthenticated() && isAdmin();
    }
    
    // ============================================
    // Groups (다락방) 컬렉션
    // ============================================
    match /groups/{groupId} {
      // 읽기: 로그인한 사용자는 모든 그룹 조회 가능
      allow read: if isAuthenticated();
      
      // 생성/수정/삭제: 리더 이상만 가능
      allow create, update, delete: if isAuthenticated() && isLeader();
    }
    
    // ============================================
    // Villages (마을) 컬렉션
    // ============================================
    match /villages/{villageId} {
      // 읽기: 로그인한 사용자는 모든 마을 조회 가능
      allow read: if isAuthenticated();
      
      // 생성/수정/삭제: 관리자만 가능
      allow create, update, delete: if isAuthenticated() && isAdmin();
    }
    
    // ============================================
    // Clubs (동아리) 컬렉션
    // ============================================
    match /clubs/{clubId} {
      // 읽기: 로그인한 사용자는 모든 동아리 조회 가능
      allow read: if isAuthenticated();
      
      // 생성: 로그인한 사용자는 동아리 신청 가능
      allow create: if isAuthenticated();
      
      // 수정: 동아리장 또는 관리자만 가능
      allow update: if isAuthenticated() && (
        resource.data.clubLeaderId == request.auth.uid || isAdmin()
      );
      
      // 삭제: 관리자만 가능
      allow delete: if isAuthenticated() && isAdmin();
    }
    
    // ============================================
    // Churches (교회) 컬렉션
    // ============================================
    match /churches/{churchId} {
      // 읽기: approved 문서는 모든 인증 사용자 조회 가능
      //       pending/rejected 문서는 신청자 본인 또는 관리자만 조회 가능
      allow read: if isAuthenticated() && (
        resource.data.status == 'approved' ||
        resource.data.requestedBy == request.auth.uid ||
        isAdmin()
      );

      // 생성: 로그인한 사용자는 교회 등록 신청 가능
      // - status는 반드시 'pending' 이어야 함 (승인 우회 차단)
      // - requestedBy는 반드시 본인 uid 이어야 함
      // - 필수 필드 존재 여부 검증
      allow create: if isAuthenticated()
        && request.resource.data.status == 'pending'
        && request.resource.data.requestedBy == request.auth.uid
        && request.resource.data.keys().hasAll([
            'name', 'address', 'seniorPastor',
            'denomination', 'requestMemo',
            'requestedBy', 'status', 'createdAt', 'updatedAt'
           ]);

      // 수정/삭제: 관리자(admin, pastor)만 가능
      allow update, delete: if isAuthenticated() && isAdmin();
    }

    // ============================================
    // Meetups (번개 모임) 컬렉션
    // ============================================
    match /meetups/{meetupId} {
      // 읽기: 로그인한 사용자는 모든 번개 조회 가능
      allow read: if isAuthenticated();
      
      // 생성: 로그인한 사용자는 번개 생성 가능
      allow create: if isAuthenticated();
      
      // 수정: 번개 주최자 또는 관리자만 가능
      allow update: if isAuthenticated() && (
        resource.data.meetLeaderId == request.auth.uid || isAdmin()
      );
      
      // 삭제: 번개 주최자 또는 관리자만 가능
      allow delete: if isAuthenticated() && (
        resource.data.meetLeaderId == request.auth.uid || isAdmin()
      );
    }
    
    // ============================================
    // Notes (메모/특이사항) 컬렉션
    // ============================================
    match /notes/{noteId} {
      // 읽기: 리더 이상만 가능 (개인정보 보호)
      allow read: if isAuthenticated() && isLeader();
      
      // 생성: 리더 이상만 가능
      allow create: if isAuthenticated() && isLeader();
      
      // 수정: 작성자 또는 관리자만 가능
      allow update: if isAuthenticated() && (
        resource.data.createdBy == request.auth.uid || isAdmin()
      );
      
      // 삭제: 관리자만 가능
      allow delete: if isAuthenticated() && isAdmin();
    }
    
    // ============================================
    // Attendances (출석 기록) 컬렉션
    // ============================================
    match /attendances/{attendanceId} {
      // 읽기: 본인 기록 또는 리더는 전체 조회 가능
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isLeader()
      );
      
      // 생성: 리더 이상만 가능 (출석 체크는 리더가 함)
      allow create: if isAuthenticated() && isLeader();
      
      // 수정: 리더 이상만 가능
      allow update: if isAuthenticated() && isLeader();
      
      // 삭제: 관리자만 가능
      allow delete: if isAuthenticated() && isAdmin();
    }
    
    // ============================================
    // 기본 거부 규칙
    // 위에서 명시적으로 허용하지 않은 모든 접근은 거부됨
    // ============================================
  }
}
